# Resend API Configuration
RESEND_API_KEY=re_your_api_key_here
ADMIN_EMAIL=your-email@example.com

# MongoDB (admin panel + bookings storage)
MONGODB_URL=mongodb+srv://user:password@cluster.mongodb.net/fixscreen?retryWrites=true&w=majority

# PostgreSQL alternative (if not using MongoDB)
# DATABASE_URL=postgresql://user:password@localhost:5432/fixscreen?schema=public

# Auth.js / NextAuth secret (generate with: openssl rand -base64 32)
AUTH_SECRET=replace-with-a-long-random-secret

# Initial admin account (used by `npm run db:seed`)
ADMIN_SEED_EMAIL=admin@fixscreenonline.com
ADMIN_SEED_PASSWORD=ChangeMe123!
