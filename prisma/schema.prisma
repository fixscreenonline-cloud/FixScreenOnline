generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URL")
}

model Admin {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  email             String    @unique
  passwordHash      String
  twoFactorSecret   String?
  twoFactorEnabled  Boolean   @default(false)
  recoveryCodesHash String?
  failedAttempts    Int       @default(0)
  lockedUntil       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  auditLogs     AuditLog[]
  loginAttempts LoginAttempt[]
  sessions      AdminSession[]
  pendingAuth   PendingAuth?

  @@map("admins")
}

model AdminSession {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  adminId      String   @db.ObjectId
  sessionToken String   @unique
  expiresAt    DateTime
  lastActivity DateTime @default(now())
  createdAt    DateTime @default(now())

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@map("admin_sessions")
}

model Booking {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  phone           String
  email           String   @default("")
  device          String
  serviceLocation String
  streetAddress   String   @default("")
  city            String   @default("")
  zip             String   @default("")
  preferredDate   String   @default("")
  preferredTime   String   @default("")
  issue           String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([createdAt])
  @@index([device])
  @@index([serviceLocation])
  @@map("bookings")
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  adminId   String?  @db.ObjectId
  action    String
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  admin Admin? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([createdAt])
  @@map("audit_logs")
}

model LoginAttempt {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  adminId   String?  @db.ObjectId
  email     String
  success   Boolean  @default(false)
  ipAddress String?
  userAgent String?
  reason    String?
  createdAt DateTime @default(now())

  admin Admin? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([createdAt])
  @@map("login_attempts")
}

model PendingAuth {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  adminId   String   @unique @db.ObjectId
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("pending_auth")
}

model OneTimeLoginToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  adminId   String   @db.ObjectId
  token     String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("one_time_login_tokens")
}
